{
  "name": "frame-syntax",
  "displayName": "Frame Syntax",
  "description": "Syntax highlighting, snippets, and language support for Frame .fr files",
  "version": "0.1.0",
  "publisher": "frame",
  "license": "MIT",
  "engines": {
    "vscode": "^1.98.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "icon": "icon.png",
  "contributes": {
    "languages": [{
      "id": "frame",
      "aliases": ["Frame", "frame"],
      "extensions": [".fr"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "frame",
      "scopeName": "source.frame",
      "path": "./syntaxes/frame.tmLanguage.json"
    }],
    "snippets": [{
      "language": "frame",
      "path": "./snippets/frame.code-snippets"
    }]
  }
}
