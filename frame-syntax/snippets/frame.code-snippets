    "prefix": "component",
    "body": [
      "component ${1:Name}: {",
      "\tprops: {",
      "\t\t${2:prop}: ${3:string} = ${4:\"\"}",
      "\t}",
      "\tstyles: {",
      "\t\tpadding: ${5:8}",
      "\t}",
      "\tchildren: [",
      "\t\t${6}",
      "\t]",
      "}"
    ],
    "description": "Create a reusable component"
  },
