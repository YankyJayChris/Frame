  "Type": {
    "prefix": [":type", "type"],
    "body": [
      ":type ${1:Name} = ${2:string}"
    ],
    "description": "Define a type alias"
  },
  "App": {
    "prefix": [":app", "app"],
    "body": [
      ":app {",
      "\ton_launch: () => {",
      "\t\t${1}",
      "\t}",
      "}"
    ],
    "description": "Define app lifecycle with on_launch handler"
  },
  "Persist": {
    "prefix": "persist:",
    "body": [
      "persist: {",
      "\tsecure: ${1:false}",
      "\tlocal: ${2:true}",
      "\tkeys: [\"${3:field}\"]",
      "}"
    ],
    "description": "Add store persistence configuration"
  },
  "Build": {
    "prefix": "build:",
    "body": [
      "build: (${1:item}, ${2:index}) => {",
      "\ttext: { content: ${1:item} }",
      "}"
    ],
    "description": "Add a list/grid builder function"
  },
  "Data": {
    "prefix": "data:",
    "body": [
      "data: ${1:href(\"/api/data\")}",
      "",
      "build: (${2:item}) => {",
      "\t${3}",
      "}"
    ],
    "description": "Add data binding with remote source"
  },
  "Watch": {
    "prefix": "watch:",
    "body": [
      "watch: ${1:StoreName.field}",
      "",
      "on_change: (${2:value}) => {",
      "\t${3}",
      "}"
    ],
    "description": "Watch a store field for changes"
  },
  "FetchWithHandlers": {
    "prefix": "wait:fetch",
    "body": [
      "wait:fetch(\"${1:url}\", {",
      "\tmethod: \"${2|GET,POST,PUT,DELETE|}\"",
      "\theaders: {",
      "\t\t\"Content-Type\": \"application/json\"",
      "\t\t${3}",
      "\t}",
      "\tbody: ${4:null}",
      "}).then((${5:res}) => {",
      "\t${6}",
      "}).catch((${7:err}) => {",
      "\t${8}",
      "})"
    ],
    "description": "Add an HTTP request with then/catch handlers"
  },
  "Plugin": {
    "prefix": "plugin:",
    "body": [
      "plugin: ${1:Name} {",
      "\t${2}",
      "}"
    ],
    "description": "Add a plugin component node"
  },
  "NavigateWithOptions": {
    "prefix": ["navigate_opts", "navigate_to"],
    "body": [
      "navigate(\"${1:/route}\", {",
      "\tanimate: ${2:true}",
      "\treplace: ${3:false}",
      "})"
    ],
    "description": "Navigate to another page with animation options"
  },
  "BottomNavBar": {
    "prefix": "bottom_nav_bar",
    "body": [
      "bottom_nav_bar: {",
      "\titems: [",
      "\t\t{ icon: \"${1:home}\", label: \"${2:Home}\" }",
      "\t\t{ icon: \"${3:search}\", label: \"${4:Search}\" }",
      "\t\t{ icon: \"${5:settings}\", label: \"${6:Settings}\" }",
      "\t]",
      "\ton_select: ${7:handler}()",
      "}"
    ],
    "description": "Add a bottom navigation bar with items"
  },
  "CameraView": {
    "prefix": "camera_view",
    "body": [
      "camera_view: {",
      "\tdirection: \"${1|back,front|}\"",
      "\tstyles: { width: 100%  height: ${2:400} }",
      "}"
    ],
    "description": "Add a camera preview"
  },
  "QrScanner": {
    "prefix": "qr_scanner",
    "body": [
      "qr_scanner: {",
      "\ton_scan: (${1:result}) => {",
      "\t\t${2}",
      "\t}",
      "\tstyles: { width: ${3:250}  height: ${4:250} }",
      "}"
    ],
    "description": "Add a QR code scanner"
  }
}
