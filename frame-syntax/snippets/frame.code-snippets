    "prefix": [":store", "store"],
    "body": [
      ":store ${1:Name} {",
      "\t:var mut ${2:field}: ${3:string} = ${4:\"\"}",
      "",
      "\tfn ${5:action}: async (${6}) => {",
      "\t\t${7}",
      "\t}",
      "}"
    ],
    "description": "Create a store for state management"
  },
  "Object": {
    "prefix": [":obj", "obj"],
