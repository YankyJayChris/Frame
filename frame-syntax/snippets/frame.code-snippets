{
  "Page": {
    "prefix": ["page", "page:"],
    "body": [
      "page: {",
      "\tname: \"${1:PageName}\"",
      "\troute: \"/${2:route}\"",
      "\tstyles: { width: 100%  height: 100% }",
      "\tchildren: [",
      "\t\t${3}",
      "\t]",
      "}"
    ],
    "description": "Create a page with route and children"
  },
  "Scaffold": {
    "prefix": "scaffold",
    "body": [
      "scaffold: {",
      "\tstyles: { safe_area: true }",
      "\tchildren: [",
      "\t\t${1}",
      "\t]",
      "}"
    ],
    "description": "Add a scaffold layout component"
  },
  "AppBar": {
    "prefix": "app_bar",
    "body": [
      "app_bar: {",
      "\ttitle: \"${1:Title}\"",
