{
    "comments": {
        "lineComment": "//",
        "blockComment": [ "/*", "*/" ]
    },
    "brackets": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"]
    ],
    "autoClosingPairs": [
        {"open": "{", "close": "}"},
        {"open": "[", "close": "]"},
        {"open": "(", "close": ")"},
        {"open": "\"", "close": "\"", "notIn": ["string"]}
    ],
    "surroundingPairs": [
        {"open": "{", "close": "}"},
        {"open": "[", "close": "]"},
        {"open": "(", "close": ")"},
        {"open": "\"", "close": "\""}
    ],
    "indentationRules": {
        "increaseIndentPattern": "^\\\\s*(page|component|fn|:vars|:i18n|:store|:obj|:enum|styles|children|items|actions|props)\\b.*{\\\\s*$",
        "decreaseIndentPattern": "^\\s*}"
    },
    "wordPattern": "(-?\\d*\\.\\d+\\w*)|([^\\s\\(\\)\\{\\}\\[\\]\":]+)",
    "onEnterRules": [
        {
            "beforeText": "^\\s*:var\\s",
            "action": { "indent": "none" }
        }
    ]
}