:store UserStore {
    user:       object = null
    is_loading: bool   = false
    auth_token: string = ""
    error:      string = ""

    persist: { auth_token: secure }

    fn load: async (id: string) => {
        UserStore.is_loading = true
        UserStore.error = ""
        UserStore.user = wait:fetch("/api/users/$id", { method: "GET" })
        UserStore.is_loading = false
    }

    fn logout: () => {
        UserStore.user = null
        UserStore.auth_token = ""
    }
}
